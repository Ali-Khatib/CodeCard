{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "build": "next build",
    "start": "next start",
    "lint": "node scripts/lint.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:hero": "playwright test e2e/hero.spec.ts",
    "test:e2e:auth": "playwright test --config playwright.e2e.config.ts auth.live.spec.ts",
    "test:e2e:profile": "playwright test --config playwright.e2e.config.ts profile.live.spec.ts",
    "test:e2e:projects": "playwright test --config playwright.e2e.config.ts projects.live.spec.ts",
    "test:e2e:research": "playwright test --config playwright.e2e.config.ts research.live.spec.ts",
    "test:e2e:public": "playwright test --config playwright.e2e.config.ts public.live.spec.ts",
    "test:e2e:account": "playwright test --config playwright.e2e.config.ts account.live.spec.ts",
    "test:e2e:analytics": "playwright test --config playwright.e2e.config.ts analytics.live.spec.ts",
    "test:e2e:live": "playwright test --config playwright.e2e.config.ts",
    "test:e2e:env": "vitest run --config vitest.e2e.config.ts src/lib/e2e/schema-readiness.livetest.ts",
    "test:e2e:smoke": "vitest run --config vitest.e2e.config.ts src/lib/e2e/smoke.livetest.ts",
    "test:e2e:reset": "vitest run --config vitest.e2e.config.ts src/lib/e2e/auth-reset.livetest.ts"
  },
  "dependencies": {
    "@codecard/analytics": "*",
    "@codecard/config": "*",
