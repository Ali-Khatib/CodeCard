# CodeCard Web — environment variable template
# Copy to apps/web/.env.local and replace placeholders. Never commit .env.local.
#
# Security:
# - Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# - All other variables are server-only. Never prefix secrets with NEXT_PUBLIC_.

# ── App URL (PUBLIC — exposed to browser) ─────────────────────────────────────
# Canonical site URL for metadata, Stripe redirect URLs, and billing callbacks.
# Local default: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase (PUBLIC — exposed to browser) ────────────────────────────────────
# Project URL from Supabase Dashboard → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Publishable key (preferred; Supabase newer naming). Safe for browser use.
# Set this OR NEXT_PUBLIC_SUPABASE_ANON_KEY — at least one is required for auth.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Legacy anon key (fallback if publishable key is not set). Safe for browser use.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Supabase (SERVER-ONLY) ────────────────────────────────────────────────────
# Service role key — bypasses RLS. Required for webhooks and admin/service clients.
# Supabase Dashboard → Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe (SERVER-ONLY) ──────────────────────────────────────────────────────
# Required for billing checkout, customer portal, and webhook verification.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRO_PRICE_ID=price_replace_me

# ── Upstash Redis (SERVER-ONLY) ───────────────────────────────────────────────
# Rate limiting for API routes. Optional in local dev; recommended in production.
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# ── Sentry (SERVER-ONLY) ──────────────────────────────────────────────────────
# Error monitoring. Optional — referenced in server env schema but not required to run locally.
SENTRY_DSN=https://your-sentry-dsn@o000000.ingest.sentry.io/0000000
