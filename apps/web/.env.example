# CodeCard Web — environment variable template
#
# Copy this file to apps/web/.env.local and replace the placeholders with real
# values. Never commit .env.local — it is git-ignored on purpose.
#
#   cp apps/web/.env.example apps/web/.env.local
#
# ─ Security model ─────────────────────────────────────────────────────────────
# - Variables prefixed with NEXT_PUBLIC_ are inlined into the browser bundle.
#   Only put values here that are safe to expose publicly.
# - Every other variable is SERVER-ONLY. Never prefix a secret with NEXT_PUBLIC_
#   and never import a server-only variable into a client component.
# - Production / Preview values live in Vercel project settings, not in source
#   control. Canonical inventory (scopes, server vs public, E2E exclusions):
#   docs/VERCEL_ENVIRONMENT.md (WS14-T013).
#
# ─ Placeholder conventions ────────────────────────────────────────────────────
# - Placeholders below are intentionally obvious and non-functional.
# - Do not paste real keys, JWTs, or copied project references into this file.


# ══════════════════════════════════════════════════════════════════════════════
# CORE — required for local development, build, and runtime
# ══════════════════════════════════════════════════════════════════════════════

# App URL (PUBLIC — browser-exposed) [required]
# Canonical site origin used for metadata, auth callbacks, Stripe redirect URLs,
# and billing return URLs. Local default: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase project URL (PUBLIC — browser-exposed) [required]
# Supabase Dashboard → Settings → API → Project URL.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase publishable key (PUBLIC — browser-exposed) [preferred]
# Newer Supabase naming. Set this OR NEXT_PUBLIC_SUPABASE_ANON_KEY — at least one
# public key is required for the client and middleware to initialize auth.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Supabase anon key (PUBLIC — browser-exposed) [fallback]
# Legacy key used only when the publishable key above is unset.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Dashboard → Authentication → URL Configuration must include a redirect
# URL for each origin, e.g. {NEXT_PUBLIC_APP_URL}/auth/callback
# See docs/AUTH_PROVIDER_CONFIGURATION.md for the full checklist.


# ══════════════════════════════════════════════════════════════════════════════
# SUPABASE ADMIN (SERVER-ONLY secret)
# ══════════════════════════════════════════════════════════════════════════════

# Service role key — bypasses Row Level Security. [required for: webhooks,
# account export/deletion, admin/service clients]. Optional only for read-only
# local browsing that never triggers those flows.
# Supabase Dashboard → Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key


# ══════════════════════════════════════════════════════════════════════════════
# STRIPE BILLING (SERVER-ONLY secrets)
# ══════════════════════════════════════════════════════════════════════════════
# Required for checkout, the customer portal, and webhook verification.
# Optional for local development that does not exercise billing.
# Use TEST-MODE keys locally. Never use live-mode keys outside production.

STRIPE_SECRET_KEY=sk_test_your_stripe_test_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_signing_secret
STRIPE_PRO_PRICE_ID=price_your_pro_plan_price_id


# ══════════════════════════════════════════════════════════════════════════════
# UPSTASH REDIS (SERVER-ONLY secrets) [optional]
# ══════════════════════════════════════════════════════════════════════════════
# Distributed rate limiting for API routes. Optional in local development;
# recommended (and enforced by strict routes) in production.

UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token


# ══════════════════════════════════════════════════════════════════════════════
# SENTRY (WS14-T015)
# ══════════════════════════════════════════════════════════════════════════════
# Error monitoring. Leave unset to disable. See docs/SENTRY.md.
#
# SENTRY_DSN is server/edge init (preferred). The DSN itself is a public Sentry
# project identifier (not an app secret), but stay server-scoped for Node/Edge.
# NEXT_PUBLIC_SENTRY_DSN is the same DSN for browser capture / global-error.
# Optional build-only source maps: SENTRY_AUTH_TOKEN, SENTRY_ORG, SENTRY_PROJECT
# (never NEXT_PUBLIC_). CODECARD_SENTRY_VERIFY=1 enables a one-shot verify route;
# leave unset in steady-state Production.

SENTRY_DSN=https://your-sentry-key@o000000.ingest.sentry.io/0000000
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-key@o000000.ingest.sentry.io/0000000
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# CODECARD_SENTRY_VERIFY=


# ══════════════════════════════════════════════════════════════════════════════
# MOBILE APP LINKS (PUBLIC — browser-exposed) [optional]
# ══════════════════════════════════════════════════════════════════════════════
# Consumed by the sitewide visitor conversion prompt. Must be HTTPS App Store /
# Play Store URLs. When unset, the "Get the app" call-to-action is hidden.

NEXT_PUBLIC_CODECARD_IOS_APP_URL=https://apps.apple.com/app/id0000000000
NEXT_PUBLIC_CODECARD_ANDROID_APP_URL=https://play.google.com/store/apps/details?id=your.app.id


# ══════════════════════════════════════════════════════════════════════════════
# TEST-ONLY (never set in production)
# ══════════════════════════════════════════════════════════════════════════════
# CODECARD_E2E_FIXTURES gates the /e2e-fixtures/* harness routes used by the
# local Playwright accessibility/UI specs. The Playwright config sets this to '1'
# automatically for its webServer; you rarely need to set it by hand.
# It must remain unset (or not '1') in production so fixture routes stay disabled.
CODECARD_E2E_FIXTURES=

# Port the local Playwright webServer starts Next.js on. Defaults to 3000.
PLAYWRIGHT_PORT=3000

# ══════════════════════════════════════════════════════════════════════════════
# ISOLATED REAL E2E BACKEND (E2E-only — never production)
# ══════════════════════════════════════════════════════════════════════════════
# These variables point at a disposable Supabase project or persistent branch
# used ONLY by WS14 real-backend Playwright tests. Production values are
# forbidden. The existing live project reference gclteunkzorwaliwhatp must never
# appear here.
#
# Put real values in apps/web/.env.e2e.local (git-ignored). Never commit that
# file. GitHub Actions secrets for these variables are configured later during
# WS14-T012 — they are not set in this template.
#
# Local UI fixture mode (CODECARD_E2E_FIXTURES=1 above) is NOT equivalent to
# real E2E mode. Real E2E additionally requires CODECARD_E2E=1 and
# CODECARD_E2E_ALLOW_DESTRUCTIVE=1 against the isolated backend.

# Explicit real-E2E mode gate. Must be '1' for any mutating E2E run.
CODECARD_E2E=

# Explicit destructive-operations gate for the isolated environment. Must be '1'.
CODECARD_E2E_ALLOW_DESTRUCTIVE=

# Isolated Supabase project URL (HTTPS). Must NOT equal NEXT_PUBLIC_SUPABASE_URL
# and must NOT be https://gclteunkzorwaliwhatp.supabase.co.
CODECARD_E2E_SUPABASE_URL=https://your-e2e-project.supabase.co

# Isolated publishable / anon key for the E2E project.
CODECARD_E2E_SUPABASE_PUBLISHABLE_KEY=your-e2e-supabase-publishable-key

# Isolated SERVICE-ROLE key (SERVER-ONLY). Never prefix with NEXT_PUBLIC_.
# Used only by trusted Node test/setup code after the environment guard passes.
CODECARD_E2E_SUPABASE_SERVICE_ROLE_KEY=your-e2e-service-role-key

# Isolated project reference. Must NOT be gclteunkzorwaliwhatp.
CODECARD_E2E_SUPABASE_PROJECT_REF=your-e2e-project-ref

# Shared password for disposable Auth users created during a run.
CODECARD_E2E_TEST_PASSWORD=your-disposable-e2e-password

# Local Playwright base URL. Must be a local host (localhost / 127.0.0.1).
CODECARD_E2E_BASE_URL=http://127.0.0.1:3000

# Optional reserved mailbox domain for disposable fixture emails.
CODECARD_E2E_EMAIL_DOMAIN=codecard-e2e.example.com

# Optional Stripe TEST-MODE credentials (only needed for subscription-backed
# account-deletion coverage). Live-mode keys are rejected by the E2E guard.
CODECARD_E2E_STRIPE_SECRET_KEY=sk_test_your_e2e_stripe_secret_key
CODECARD_E2E_STRIPE_WEBHOOK_SECRET=whsec_your_e2e_stripe_webhook_secret
CODECARD_E2E_STRIPE_PRICE_ID=price_your_e2e_pro_plan_price_id

# Optional Mailtrap Email Sandbox capture (WS14-T002 real password-reset E2E).
# The isolated Supabase project sends auth emails through the Mailtrap Sandbox
# SMTP (configured in the Supabase Dashboard, never in this repo). These API
# credentials let tests read captured messages and extract recovery links.
# SERVER-ONLY test credentials — never production SMTP, never NEXT_PUBLIC_.
CODECARD_E2E_MAILTRAP_API_TOKEN=your-mailtrap-api-token
CODECARD_E2E_MAILTRAP_ACCOUNT_ID=your-mailtrap-account-id
CODECARD_E2E_MAILTRAP_INBOX_ID=your-mailtrap-inbox-id


# ══════════════════════════════════════════════════════════════════════════════
# PLATFORM-PROVIDED (do not set manually)
# ══════════════════════════════════════════════════════════════════════════════
# VERCEL_URL is injected automatically by Vercel at build/runtime and is used as a
# fallback same-origin source. Do not define it in .env.local.
