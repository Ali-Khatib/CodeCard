{
  "name": "codecard",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "node scripts/start.mjs",
    "start:mobile": "node scripts/start.mjs --mobile",
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "db:seed": "tsx supabase/seed.ts",
    "security:scan": "node scripts/check-secrets.js"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.10.4",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.0"
}
