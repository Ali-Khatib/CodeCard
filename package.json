{
  "name": "codecard",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "node scripts/start.mjs",
    "start:mobile": "node scripts/start.mjs --mobile",
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:migrate": "npx supabase db push",
    "db:reset": "npx supabase db reset",
    "db:seed": "tsx supabase/seed.ts",
    "security:scan": "node scripts/check-secrets.js",
    "security:audit": "npm audit --audit-level=high --package-lock-only"
  },
  "devDependencies": {
    "prettier": "^3.9.6",
    "tsx": "^4.19.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.0"
}
